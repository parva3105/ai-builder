# ─── Database ────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://tailorflow:tailorflow@localhost:5432/tailorflow
POSTGRES_USER=tailorflow
POSTGRES_PASSWORD=tailorflow
POSTGRES_DB=tailorflow

# ─── Auth / JWT ──────────────────────────────────────────────
JWT_SECRET_KEY=change-me-to-a-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ─── OpenAI ──────────────────────────────────────────────────
OPENAI_API_KEY=sk-your-openai-key-here
OPENAI_MODEL=gpt-4o

# ─── File Storage ────────────────────────────────────────────
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=10

# ─── LaTeX Sandbox ───────────────────────────────────────────
LATEX_COMPILE_TIMEOUT_SECONDS=60

# ─── App ─────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:3000
ENVIRONMENT=development

# ─── Frontend ────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
